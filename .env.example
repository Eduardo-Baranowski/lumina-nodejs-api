# ─── Banco de dados ──────────────────────────────────────────────────────────
# Local (dev):
# DATABASE_URL=postgresql://postgres:SENHA@localhost:5432/il_libro_amico_db

# Supabase (produção) — encode o @ da senha como %40:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:%40SUPABASE_PASSWORD@aws-1-us-east-2.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:SENHA@localhost:5432/il_libro_amico_db

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URL base da API (usado para gerar URLs de imagens sem req disponível)
# Em produção: https://seu-projeto.vercel.app
BASE_URL=http://localhost:5000

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=sua_chave_jwt_super_secreta_aqui

# ─── Admin inicial ───────────────────────────────────────────────────────────
ADMIN_INITIAL_EMAIL=admin@sistema.com.br
ADMIN_INITIAL_PASSWORD=admin123

# ─── Cloudinary (Produção) ──────────────────────────────────────────────────
# IMPORTANTE: Recomendado para Vercel (filesystem efêmero)
# Criar conta gratuita em https://cloudinary.com
# Deixar vazio em dev para usar filesystem local (/static/uploads)
# CLOUDINARY_CLOUD_NAME=seu_cloud_name
# CLOUDINARY_API_KEY=sua_api_key
# CLOUDINARY_API_SECRET=seu_api_secret

