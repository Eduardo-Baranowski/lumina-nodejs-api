# ─── Banco de dados ──────────────────────────────────────────────────────────
# Local (dev):
# DATABASE_URL=mysql://root:SENHA@localhost:3306/il_libro_amico_db

# Railway / Planetscale / MySQL hospedado:
# DATABASE_URL=mysql://usuario:SENHA@host:3306/nome_do_banco?ssl=true
DATABASE_URL=mysql://root:SENHA@localhost:3306/il_libro_amico_db

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# URL base da API (usado para gerar URLs de imagens sem req disponível)
# Em produção: https://seu-projeto.vercel.app
BASE_URL=http://localhost:5000

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=sua_chave_jwt_super_secreta_aqui

# ─── Admin inicial ───────────────────────────────────────────────────────────
ADMIN_INITIAL_EMAIL=admin@sistema.com.br
ADMIN_INITIAL_PASSWORD=admin123

# ─── Email SMTP / SendGrid / Mailgun ───────────────────────────────────────
# Configure este bloco para ativar o envio de emails.
PASSWORD_RESET_EMAIL_ENABLED=0
EMAIL_SMTP_HOST=smtp.exemplo.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=0
EMAIL_SMTP_USER=seu_usuario
EMAIL_SMTP_PASS=sua_senha
EMAIL_FROM="Lumina <no-reply@seudomínio.com>"

# ─── Cloudinary (Produção) ──────────────────────────────────────────────────
# IMPORTANTE: Recomendado para Vercel (filesystem efêmero)
# Criar conta gratuita em https://cloudinary.com
# Deixar vazio em dev para usar filesystem local (/static/uploads)
# CLOUDINARY_CLOUD_NAME=seu_cloud_name
# CLOUDINARY_API_KEY=sua_api_key
# CLOUDINARY_API_SECRET=seu_api_secret

